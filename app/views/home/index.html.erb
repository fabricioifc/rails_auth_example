<%= content_for :title, "Home" %>

<div class="home-hero">
  <h1>Bem-vindo</h1>
  <% if session[:user_id] %>
    <p>Você já está logado. <a href="/protected">Acessar área protegida</a></p>
  <% else %>
    <p>Faça login com sua conta GitHub para continuar.</p>
    <a href="/auth/github" class="btn btn--dark">Login com GitHub</a>
  <% end %>
</div>
